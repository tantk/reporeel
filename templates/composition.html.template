<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=1920, height=1080" />
    <title>__TITLE__ — Hyperframes composition</title>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.14.2/dist/gsap.min.js"></script>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body {
        margin: 0;
        width: 1920px;
        height: 1080px;
        overflow: hidden;
        background: #0a0a12;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", sans-serif;
        color: #fff;
      }
      .clip { position: absolute; inset: 0; }
      .bg {
        background:
          radial-gradient(circle at 25% 20%, rgba(111,111,255,0.18) 0%, transparent 50%),
          radial-gradient(circle at 75% 80%, rgba(200,95,69,0.12) 0%, transparent 55%),
          linear-gradient(180deg, #0a0a14 0%, #050510 100%);
      }
      .avatar-frame {
        position: absolute;
        right: 90px;
        bottom: 120px;
        width: 540px;
        height: 540px;
        border-radius: 36px;
        background: linear-gradient(135deg, #14142a 0%, #0a0a18 100%);
        box-shadow:
          0 30px 80px rgba(0,0,0,0.55),
          0 0 0 3px rgba(111,111,255,0.35),
          0 0 60px rgba(111,111,255,0.25);
        inset: auto 90px 120px auto;
        z-index: 4;
        pointer-events: none;
      }
      .avatar-video {
        position: absolute;
        right: 90px;
        bottom: 120px;
        width: 540px;
        height: 540px;
        border-radius: 36px;
        object-fit: cover;
        inset: auto 90px 120px auto;
        z-index: 5;
        overflow: hidden;
      }
      .title-card {
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
      }
      .title-card .inner { padding: 0 6rem; }
      .title-card .eyebrow {
        font-size: 28px;
        letter-spacing: 0.45em;
        text-transform: uppercase;
        color: #8a8aff;
        margin-bottom: 1.5rem;
        font-weight: 500;
      }
      .title-card h1 {
        font-size: 168px;
        line-height: 1.0;
        font-weight: 800;
        letter-spacing: -0.04em;
        background: linear-gradient(135deg, #fff 0%, #b8b8ff 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .scene-label {
        position: absolute;
        bottom: 80px;
        left: 90px;
        font-size: 32px;
        font-weight: 600;
        background: rgba(20,20,40,0.7);
        padding: 18px 30px;
        border-radius: 14px;
        border: 1px solid rgba(140,140,255,0.25);
        backdrop-filter: blur(8px);
        inset: auto auto 80px 90px;
        width: max-content;
        z-index: 4;
      }
      .stage {
        position: absolute;
        top: 100px;
        left: 90px;
        right: 700px;
        bottom: 200px;
        z-index: 3;
      }
      .repo-card {
        display: flex;
        flex-direction: column;
        justify-content: center;
        height: 100%;
      }
      .repo-card .label {
        font-size: 22px;
        letter-spacing: 0.4em;
        text-transform: uppercase;
        color: #8a8aff;
        font-weight: 500;
        margin-bottom: 30px;
      }
      .repo-card h2 {
        font-size: 110px;
        line-height: 0.95;
        font-weight: 800;
        letter-spacing: -0.03em;
        margin-bottom: 40px;
        max-width: 100%;
        word-wrap: break-word;
      }
      .repo-card .tagline {
        font-size: 32px;
        opacity: 0.78;
        font-weight: 400;
        line-height: 1.35;
        max-width: 900px;
        margin-bottom: 50px;
      }
      .repo-card .stats {
        display: flex;
        gap: 60px;
        font-size: 32px;
        flex-wrap: wrap;
      }
      .repo-card .stat {
        display: flex;
        flex-direction: column;
        gap: 6px;
      }
      .repo-card .stat .num {
        font-weight: 700;
        font-size: 40px;
      }
      .repo-card .stat .lbl {
        opacity: 0.55;
        font-size: 20px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }
      .pipeline {
        display: flex;
        flex-direction: column;
        justify-content: center;
        height: 100%;
        gap: 36px;
      }
      .pipeline .label {
        font-size: 22px;
        letter-spacing: 0.4em;
        text-transform: uppercase;
        color: #8a8aff;
        font-weight: 500;
        margin-bottom: 20px;
      }
      .step {
        display: flex;
        align-items: center;
        gap: 28px;
        font-size: 38px;
      }
      .step .badge {
        width: 78px;
        height: 78px;
        border-radius: 22px;
        background: linear-gradient(135deg, #6f6fff, #4040c0);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 36px;
        font-weight: 700;
        box-shadow: 0 8px 24px rgba(111,111,255,0.35);
        flex-shrink: 0;
      }
      .step .body { line-height: 1.25; }
      .step .name { font-weight: 600; }
      .step .desc {
        font-size: 24px;
        opacity: 0.6;
        margin-top: 6px;
      }
      .terminal {
        background: #0c0c18;
        border-radius: 18px;
        border: 1px solid rgba(140,140,255,0.2);
        padding: 0;
        height: 100%;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0,0,0,0.4);
      }
      .term-bar {
        height: 48px;
        background: #1a1a28;
        display: flex;
        align-items: center;
        padding: 0 22px;
        gap: 10px;
        border-bottom: 1px solid rgba(140,140,255,0.15);
      }
      .term-bar .dot { width: 14px; height: 14px; border-radius: 50%; }
      .term-bar .dot.r { background: #ff5f57; }
      .term-bar .dot.y { background: #ffbd2e; }
      .term-bar .dot.g { background: #28c941; }
      .term-bar .title {
        margin-left: 18px;
        font-size: 18px;
        opacity: 0.5;
        font-family: "SF Mono", "Consolas", monospace;
      }
      .term-body {
        padding: 36px 40px;
        font-family: "SF Mono", "Consolas", "Cascadia Code", monospace;
        font-size: 26px;
        line-height: 1.55;
        color: #e0e0ff;
        flex: 1;
      }
      .term-body .prompt { color: #6fff8a; font-weight: 600; }
      .term-body .cmd { color: #fff; }
      .term-body .out { color: #b0b0c8; opacity: 0.85; }
      .term-body .accent { color: #8a8aff; }
      .outro h2 {
        font-size: 110px;
        font-weight: 800;
        background: linear-gradient(135deg, #fff 0%, #b8b8ff 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .outro p {
        font-size: 36px;
        opacity: 0.55;
        margin-top: 1.5rem;
        font-family: "SF Mono", "Consolas", monospace;
      }
    </style>
  </head>
  <body>
    <div
      id="root"
      data-composition-id="main"
      data-start="0"
      data-duration="__TOTAL__"
      data-width="1920"
      data-height="1080"
    >
      <div id="bg" class="clip bg" data-start="0" data-duration="__TOTAL__" data-track-index="0"></div>

      <div id="avatar-frame" class="clip avatar-frame" data-start="2" data-duration="__AVATAR_DUR__" data-track-index="2"></div>

      <video id="vid-intro" class="clip avatar-video" src="assets/intro.mp4"
             data-start="__INTRO_START__" data-duration="__INTRO_DUR__" data-track-index="5"
             data-has-audio="true" data-volume="1"
             preload="auto" playsinline></video>
      <video id="vid-tour" class="clip avatar-video" src="assets/tour.mp4"
             data-start="__TOUR_START__" data-duration="__TOUR_DUR__" data-track-index="5"
             data-has-audio="true" data-volume="1"
             preload="auto" playsinline></video>
      <video id="vid-run" class="clip avatar-video" src="assets/run.mp4"
             data-start="__RUN_START__" data-duration="__RUN_DUR__" data-track-index="5"
             data-has-audio="true" data-volume="1"
             preload="auto" playsinline></video>

      <div id="title-open" class="clip title-card" data-start="0" data-duration="2" data-track-index="3">
        <div class="inner">
          <div class="eyebrow">RepoReel</div>
          <h1 id="title-text">__TITLE__</h1>
        </div>
      </div>

      <div id="scene-1" class="clip stage" data-start="__INTRO_START__" data-duration="__INTRO_DUR__" data-track-index="3">
        <div class="repo-card">
          <div class="label">__OWNER_REPO__</div>
          <h2 id="rc-name">__REPO_NAME__</h2>
          <div class="tagline" id="rc-tag">__TAGLINE__</div>
          <div class="stats">
            __STATS_HTML__
          </div>
        </div>
      </div>
      <div id="lbl-intro" class="clip scene-label" data-start="__INTRO_START__" data-duration="__INTRO_DUR__" data-track-index="4">
        01 · What is this?
      </div>

      <div id="scene-2" class="clip stage" data-start="__TOUR_START__" data-duration="__TOUR_DUR__" data-track-index="3">
        <div class="pipeline">
          <div class="label">__TOUR_LABEL__</div>
          __STEPS_HTML__
        </div>
      </div>
      <div id="lbl-tour" class="clip scene-label" data-start="__TOUR_START__" data-duration="__TOUR_DUR__" data-track-index="4">
        02 · How it works
      </div>

      <div id="scene-3" class="clip stage" data-start="__RUN_START__" data-duration="__RUN_DUR__" data-track-index="3">
        <div class="terminal">
          <div class="term-bar">
            <div class="dot r"></div><div class="dot y"></div><div class="dot g"></div>
            <span class="title">__TERMINAL_TITLE__</span>
          </div>
          <div class="term-body">
            __LINES_HTML__
          </div>
        </div>
      </div>
      <div id="lbl-run" class="clip scene-label" data-start="__RUN_START__" data-duration="__RUN_DUR__" data-track-index="4">
        03 · Try it
      </div>

      <div id="outro" class="clip outro title-card" data-start="__OUTRO_START__" data-duration="1" data-track-index="3">
        <div class="inner">
          <h2>Made with RepoReel</h2>
          <p>/reporeel · HeyGen Hackathon 2026</p>
        </div>
      </div>
    </div>

    <script>
      window.__timelines = window.__timelines || {};
      const tl = gsap.timeline({ paused: true });

      // Opening title
      tl.from("#title-open .inner", { opacity: 0, y: 30, duration: 0.6, ease: "power2.out" }, 0);
      tl.to("#title-open", { opacity: 0, duration: 0.5, ease: "power2.in" }, 1.5);
      tl.set("#title-open", { opacity: 0 }, 2.0);

      // Avatar frame slides in at 2
      tl.from("#avatar-frame", { opacity: 0, x: 80, duration: 0.6, ease: "power2.out" }, 2.0);

      // Scene 1: repo card stagger (starts at __INTRO_START__)
      tl.from("#scene-1 .label",   { opacity: 0, x: -40, duration: 0.5, ease: "power2.out" }, __INTRO_START__ + 0.3);
      tl.from("#scene-1 h2",       { opacity: 0, y: 30, duration: 0.6, ease: "power2.out" }, __INTRO_START__ + 0.5);
      tl.from("#scene-1 .tagline", { opacity: 0, y: 20, duration: 0.6, ease: "power2.out" }, __INTRO_START__ + 0.9);
      tl.from("#scene-1 .stat",    { opacity: 0, y: 20, duration: 0.5, stagger: 0.15, ease: "power2.out" }, __INTRO_START__ + 1.3);
      tl.to("#scene-1",            { opacity: 0, duration: 0.4, ease: "power2.in" }, __TOUR_START__ - 0.6);
      tl.set("#scene-1", { opacity: 0 }, __TOUR_START__);

      // Scene 2: pipeline steps stagger
      tl.from("#scene-2 .label", { opacity: 0, x: -40, duration: 0.5, ease: "power2.out" }, __TOUR_START__ + 0.3);
__STEPS_GSAP__
      tl.to("#scene-2", { opacity: 0, duration: 0.4, ease: "power2.in" }, __RUN_START__ - 0.6);
      tl.set("#scene-2", { opacity: 0 }, __RUN_START__);

      // Scene 3: terminal lines stagger
      tl.from("#scene-3 .terminal", { opacity: 0, y: 30, duration: 0.6, ease: "power2.out" }, __RUN_START__ + 0.3);
      tl.from("#scene-3 .term-body > div", { opacity: 0, y: 8, duration: 0.3, stagger: 0.5, ease: "power2.out" }, __RUN_START__ + 1.0);
      tl.to("#scene-3", { opacity: 0, duration: 0.4, ease: "power2.in" }, __OUTRO_START__ - 0.6);
      tl.set("#scene-3", { opacity: 0 }, __OUTRO_START__);

      // Avatar frame fades out just before outro
      tl.to("#avatar-frame", { opacity: 0, duration: 0.6, ease: "power2.in" }, __OUTRO_START__ - 0.8);

      // Outro
      tl.from("#outro .inner", { opacity: 0, scale: 0.92, duration: 0.6, ease: "power2.out" }, __OUTRO_START__);

      window.__timelines["main"] = tl;
    </script>
  </body>
</html>
